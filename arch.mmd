graph TD
    %% Define Styles
    classDef frontend fill:#3b82f6,stroke:#2563eb,stroke-width:2px,color:#fff;
    classDef backend fill:#10b981,stroke:#059669,stroke-width:2px,color:#fff;
    classDef db fill:#f59e0b,stroke:#d97706,stroke-width:2px,color:#fff;
    classDef mcp fill:#8b5cf6,stroke:#7c3aed,stroke-width:2px,color:#fff;
    classDef external fill:#6b7280,stroke:#4b5563,stroke-width:2px,color:#fff,stroke-dasharray: 5 5;

    %% Nodes
    User(("User (Browser)"))

    subgraph "Kiwi-AI System Architecture"
    
        %% Frontend
        FE["Frontend Application<br/>(React, Vite, Tailwind, Monaco)<br/>Port: client-side"]:::frontend
        
        %% Backends
        B1["Backend-1: Builder Service<br/>(Node.js, Express, TS)<br/>Port: ?"]:::backend
        B3["Backend-3: Research Service<br/>(Python, FastAPI, Langchain, ChromaDB)<br/>Port: ?"]:::backend
        
        %% Model Context Protocol
        MCP["Grow-MCP Service<br/>(Node.js, Express, MCP SDK)<br/>Port: ?"]:::mcp
        
        %% Database
        DB[("PostgreSQL Database<br/>(Docker: postgres:16-alpine)<br/>Port: 5432")]:::db
        
    end

    %% External Services
    ExtAuth["Clerk Auth<br/>(Authentication)"]:::external
    ExtOpenAI["OpenAI API<br/>(LLMs)"]:::external
    ExtNvidia["Nvidia AI Endpoints<br/>(DeepAgents)"]:::external
    ExtArxiv["ArXiv API<br/>(Research Papers)"]:::external

    %% Connections User -> Frontend
    User -->|Interacts| FE
    
    %% Frontend -> Backends & External
    FE <-->|Auth Tokens| ExtAuth
    FE -->|REST HTTP| B1
    FE -->|REST/Streams| B3
    FE -.->|Context Protocol| MCP

    %% Backend-1 Connections
    B1 <-->|Validates| ExtAuth
    B1 -->|SQL Queries| DB
    B1 <-->|LLM Calls| ExtOpenAI

    %% Backend-3 Connections
    B3 -->|SQL Queries| DB
    B3 <-->|LLM/Vector Ops| ExtNvidia
    B3 <-->|Fetch Papers| ExtArxiv

    %% MCP Connections
    MCP <-->|LLM Tools| ExtOpenAI

    %% Layout constraints
    FE --- B1
    FE --- B3
